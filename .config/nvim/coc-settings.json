{
  "javascript.suggestionActions.enabled": false,
  "languageserver": {
    "haskell": {
      "command": "haskell-language-server-wrapper",
      "args": ["--lsp"],
      "rootPatterns": ["*.cabal", "stack.yaml", "cabal.project", "package.yaml", "hie.yaml"],
      "filetypes": ["haskell", "lhaskell"]
    }
  },
  "prettier.printWidth": 140,
  "graphql.filetypes": ["graphql"],
  "tailwindCSS.jsLanguages": ["javascript", "javascriptreact", "reason", "typescriptreact", "svelte"],
  "explorer.keyMappings.global": {
    "dd": "cutFile",
    "p": "pasteFile",
    "I": "toggleHidden",
    "u": ["wait", "collapse", "gotoParent", "normal:G"],
    "<cr>": ["wait", "expandable?", ["cd", "normal:G"] , "open"],
    "t": false
  },
  "explorer.floating.border.title": "",
  "explorer.quitOnOpen": true,
  "explorer.buffer.tabOnly": true
}
